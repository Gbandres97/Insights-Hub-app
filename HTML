                 className={`px-3 py-1 text-xs font-bold rounded-md transition-all ${lang === 'en' ? 'bg-[#5e4b8a] text-white shadow-sm' : 'text-slate-500 hover:text-slate-800'}`}
               >
                 EN
               </button>
             </div>

             <div className="w-8 h-8 bg-blue-100 text-[#0078d4] rounded-full flex items-center justify-center font-bold border-2 border-white shadow-sm ml-2" title={`${t.header.hello}, AG`}>
               AG
             </div>
          </div>
        </header>

        {/* CONTENIDO SCROLL */}
        <div className="flex-1 overflow-y-auto p-8 lg:p-12">
          <div className="max-w-5xl mx-auto">
            {activeSection === 'inicio' && <SectionInicio />}
            {activeSection === 'consultar' && <SectionConsultar />}
            {activeSection === 'cargar' && <SectionCargar />}
            {activeSection === 'editar' && <SectionEditar />}
            {activeSection === 'notificaciones' && <SectionNotificaciones />}
          </div>
        </div>
      </main>
    </div>
  );
}
